# =============================================
# Frontend Environment Variables
# Copy this file to `.env` and fill in your values
# =============================================

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Firebase
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Delhivery (server-side only — set via `supabase secrets set`)
# DO NOT add VITE_ prefixed Delhivery variables here

# Razorpay (public key only — secret is in Edge Functions)
VITE_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXX
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ML API URL
VITE_ML_API_URL=https://your-ml-api.onrender.com

# Umami Analytics
VITE_UMAMI_WEBSITE_ID=your_umami_website_id

# Cloudflare R2
VITE_R2_WORKER_URL=https://your-worker.workers.dev
